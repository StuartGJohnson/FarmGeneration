    def Scope "Materials"
    {
        def Material "FennelMat_fennel"
        {
            token outputs:surface.connect = </Fennel/Materials/FennelMat_fennel/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor.connect = </Fennel/Materials/FennelMat_fennel/Texture.outputs:rgb>
                float inputs:opacity.connect = </Fennel/Materials/FennelMat_fennel/Texture.outputs:a>
                float inputs:opacityThreshold = 0.45
                float inputs:roughness = 0.4
                color3f inputs:specularColor = (0.04, 0.04, 0.04)
                token outputs:surface
            }

            def Shader "Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @textures/fennel_diffuse.png@
                float2 inputs:st.connect = </Fennel/Materials/FennelMat_fennel/PrimvarReader.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float outputs:a
                float3 outputs:rgb
            }

            def Shader "PrimvarReader"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                token inputs:varname = "st"
                float2 outputs:result
            }
        }
    }
}

