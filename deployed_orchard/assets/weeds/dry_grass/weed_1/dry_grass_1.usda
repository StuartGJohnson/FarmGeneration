            interpolation = "varying"
        )
        uniform token subdivisionScheme = "none"
    }

    def Scope "Materials"
    {
        def Material "GrassMat"
        {
            token outputs:surface.connect = </DryGrass/Materials/GrassMat/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor.connect = </DryGrass/Materials/GrassMat/Texture.outputs:rgb>
                float inputs:roughness = 0.8
                color3f inputs:specularColor = (0.02, 0.02, 0.02)
                token outputs:surface
            }

            def Shader "Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/dry_grass_diffuse.png@
                float2 inputs:st.connect = </DryGrass/Materials/GrassMat/PrimvarReader.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "PrimvarReader"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                token inputs:varname = "st"
                float2 outputs:result
            }
        }
    }
}

