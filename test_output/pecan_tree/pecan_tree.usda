            interpolation = "varying"
        )
        uniform token subdivisionScheme = "none"
    }

    def Scope "Materials"
    {
        def Material "BarkMat"
        {
            token outputs:surface.connect = </PecanTree/Materials/BarkMat/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor.connect = </PecanTree/Materials/BarkMat/Texture.outputs:rgb>
                float inputs:roughness = 0.85
                color3f inputs:specularColor = (0.03, 0.03, 0.03)
                token outputs:surface
            }

            def Shader "Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @textures/bark_diffuse.png@
                float2 inputs:st.connect = </PecanTree/Materials/BarkMat/PrimvarReader.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "PrimvarReader"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                token inputs:varname = "st"
                float2 outputs:result
            }
        }

        def Material "LeafMat"
        {
            token outputs:surface.connect = </PecanTree/Materials/LeafMat/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor.connect = </PecanTree/Materials/LeafMat/Texture.outputs:rgb>
                float inputs:opacity.connect = </PecanTree/Materials/LeafMat/Texture.outputs:a>
                float inputs:opacityThreshold = 0.4
                float inputs:roughness = 0.35
                color3f inputs:specularColor = (0.05, 0.05, 0.05)
                token outputs:surface
            }

            def Shader "Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @textures/leaf_diffuse.png@
                float2 inputs:st.connect = </PecanTree/Materials/LeafMat/PrimvarReader.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float outputs:a
                float3 outputs:rgb
            }

            def Shader "PrimvarReader"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                token inputs:varname = "st"
                float2 outputs:result
            }
        }
    }
}

