    def Scope "Lights"
    {
        def DistantLight "Sun" (
            prepend apiSchemas = ["ShadowAPI"]
        )
        {
            float inputs:angle = 0.53
            color3f inputs:color = (1, 0.95, 0.85)
            float inputs:intensity = 1000
            bool inputs:shadow:enable = 1
            float3 xformOp:rotateXYZ = (35, -25, 0)
            uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
        }

        def DomeLight "Sky"
        {
            float inputs:intensity = 500
            asset inputs:texture:file = @../assets/dome_texture_no_clouds.png@
            token inputs:texture:format = "latlong"
        }
    }

    def Mesh "GroundPlane" (
        prepend apiSchemas = ["PhysicsCollisionAPI", "MaterialBindingAPI"]
    )
    {
        float3[] extent = [(-4, -4, 0), (12, 8, 0)]
        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [0, 1, 2, 3]
        rel material:binding = </World/Materials/GroundPlaneMat>
        bool physics:collisionEnabled = 1
        point3f[] points = [(-4, -4, 0), (12, -4, 0), (12, 8, 0), (-4, 8, 0)]
        texCoord2f[] primvars:st = [(0, 0), (4, 0), (4, 3), (0, 3)] (
            interpolation = "faceVarying"
        )
        uniform token subdivisionScheme = "none"
        token visibility = "inherited"
    }

    def Scope "Materials"
    {
        def Material "GroundPlaneMat"
        {
            token outputs:surface.connect = </World/Materials/GroundPlaneMat/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor.connect = </World/Materials/GroundPlaneMat/GroundTexture.outputs:rgb>
                float inputs:metallic = 0
                float inputs:roughness = 0.95
                color3f inputs:specularColor = (0.02, 0.02, 0.02)
                token outputs:surface
            }

            def Shader "GroundTexture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @../assets/ground_plane.png@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </World/Materials/GroundPlaneMat/PrimvarReader.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "PrimvarReader"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                token inputs:varname = "st"
                float2 outputs:result
            }
        }
    }
}

