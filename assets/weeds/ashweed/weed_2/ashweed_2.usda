            interpolation = "varying"
        )
        uniform token subdivisionScheme = "none"
    }

    def Scope "Materials"
    {
        def Material "AshweedMat"
        {
            token outputs:surface.connect = </Ashweed/Materials/AshweedMat/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor.connect = </Ashweed/Materials/AshweedMat/Texture.outputs:rgb>
                float inputs:opacity.connect = </Ashweed/Materials/AshweedMat/Texture.outputs:a>
                float inputs:opacityThreshold = 0.4
                float inputs:roughness = 0.38
                color3f inputs:specularColor = (0.03, 0.03, 0.03)
                token outputs:surface
            }

            def Shader "Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/ashweed_diffuse.png@
                float2 inputs:st.connect = </Ashweed/Materials/AshweedMat/PrimvarReader.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float outputs:a
                float3 outputs:rgb
            }

            def Shader "PrimvarReader"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                token inputs:varname = "st"
                float2 outputs:result
            }
        }
    }
}

